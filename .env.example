# Banco de dados PostgreSQL (ex: Supabase). No Supabase, pegue as duas strings em
# Project Settings > Database > Connection string.
# DATABASE_URL: connection pooling (porta 6543, ?pgbouncer=true) - usada em runtime.
# DIRECT_URL: conexão direta (porta 5432) - usada apenas para migrations (db push).
DATABASE_URL="postgresql://postgres.xxxxxxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

AUTH_SECRET="troque-este-segredo-por-uma-string-aleatoria-longa"

# IA (opcional): chave do Google Gemini (AI Studio - plano gratuito).
# Pegue em https://aistudio.google.com/apikey . Sem ela, o assistente fica desativado.
GEMINI_API_KEY=""
