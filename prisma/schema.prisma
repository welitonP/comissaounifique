generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  modality    String
  createdAt   DateTime @default(now())
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
}

model Championship {
  id        String   @id @default(cuid())
  name      String
  season    String
  createdAt DateTime @default(now())
  matches   Match[]
}

model Match {
  id             String        @id @default(cuid())
  championshipId String?
  championship   Championship? @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  homeTeamId     String
  homeTeam       Team          @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeamId     String
  awayTeam       Team          @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  date           DateTime
  location       String?
  homeScore      Int?
  awayScore      Int?
  status         String        @default("scheduled")
  createdAt      DateTime      @default(now())
}

model Announcement {
  id        String              @id @default(cuid())
  title     String
  body      String
  createdAt DateTime            @default(now())
  images    AnnouncementImage[]
}

// Foto anexada a um comunicado (bytes servidos por /api/imagens/[id])
model AnnouncementImage {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  data           Bytes
  mime           String
  createdAt      DateTime     @default(now())
}

// Sugestão enviada por atleta (nome opcional; visível só para a comissão)
model Suggestion {
  id        String   @id @default(cuid())
  name      String?
  message   String
  status    String   @default("nova") // "nova" | "analise" | "concluida"
  createdAt DateTime @default(now())
}

// Membro da comissão (vitrine institucional "A Comissão")
model CommissionMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  whatsapp  String?
  photoData Bytes?
  photoMime String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Resultado/conquista da Unifique em uma modalidade
model Result {
  id        String   @id @default(cuid())
  event     String // ex: "35ª OEE 2026"
  year      Int
  modality  String // ex: "Futsal Masculino"
  placement String // ex: "Campeão", "Vice-campeão", "3º lugar"
  medal     String? // "ouro" | "prata" | "bronze" | null
  note      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Configurações simples chave/valor (ex: inscrições abertas)
model Setting {
  key   String @id
  value String
}

// Inscrição online de um atleta em uma ou mais modalidades (fila de aprovação)
model Enrollment {
  id            String   @id @default(cuid())
  name          String
  sector        String?
  shirtSize     String?
  contact       String?
  modalityIds   String // ids das modalidades escolhidas (CSV)
  modalityNames String // nomes (snapshot) para exibição (CSV)
  status        String   @default("pendente") // pendente | aprovada | recusada
  createdAt     DateTime @default(now())
}

// Kit padrão de equipamentos (lista pronta por modalidade)
model EquipmentKit {
  id        String   @id @default(cuid())
  name      String
  items     String // itens padrão, um por linha
  createdAt DateTime @default(now())
}

// Saída de equipamento para um jogo/evento (controle do que levou/devolveu)
model Checkout {
  id          String         @id @default(cuid())
  title       String
  eventId     String? // opcional: jogo do calendário de origem
  date        DateTime
  responsible String?
  status      String         @default("aberto") // aberto | devolvido
  createdAt   DateTime       @default(now())
  items       CheckoutItem[]
}

model CheckoutItem {
  id         String   @id @default(cuid())
  checkoutId String
  checkout   Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  name       String
  taken      Boolean  @default(false)
  returned   Boolean  @default(false)
}

// Confirmação de presença em um evento (visível só para a comissão)
model EventRsvp {
  id        String        @id @default(cuid())
  eventId   String
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  going     Boolean       @default(true)
  createdAt DateTime      @default(now())
}

model Poll {
  id        String       @id @default(cuid())
  question  String
  createdAt DateTime     @default(now())
  options   PollOption[]
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  Int    @default(0)
}

// Modalidade do campeonato "Entre Empresas" (ex: Futsal, Vôlei, Truco...)
model Modality {
  id            String         @id @default(cuid())
  name          String
  description   String?
  info          String?        // regras / informações gerais exibidas na aba
  order         Int            @default(0)
  createdAt     DateTime       @default(now())
  registrations Registration[]
  events        CalendarEvent[]
}

// Empresa/time inscrito em uma modalidade do Entre Empresas
model Registration {
  id          String   @id @default(cuid())
  modalityId  String
  modality    Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  companyName String   // nome da empresa/time inscrito
  responsible String?  // responsável
  contact     String?  // telefone/e-mail
  createdAt   DateTime @default(now())
}

// Datas do calendário, visíveis a todos (ex: 17/07 - Futsal)
model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  date        DateTime
  modalityId  String?
  modality    Modality? @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  location    String?
  description String?
  createdAt   DateTime  @default(now())
  rsvps       EventRsvp[]
}

// Estoque de materiais esportivos (ex: 5 bolas de futsal)
model Material {
  id        String   @id @default(cuid())
  name      String
  category  String?  // ex: Futsal, Vôlei, Geral
  quantity  Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
}

// Membro da comissão com login individual
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique // ex: weliton.porto
  passwordHash String
  role         String   @default("member") // "admin" | "member"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// Item individual controlado (ex: bolsa de uniforme) e quem está com ele
model TrackedItem {
  id         String    @id @default(cuid())
  name       String
  category   String?   // ex: Uniforme Futsal, Uniforme Vôlei
  holderName String?   // quem está com o item (null = na comissão / disponível)
  since      DateTime? // desde quando está emprestado
  notes      String?
  createdAt  DateTime  @default(now())
}
